          "legendFormat": "Durée moy. {{module}} (s)",
          "refId": "A"
        }
      ],
      "title": "Durée de traitement par module",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "nlp_sentiment_score",
          "interval": "",
          "legendFormat": "Score de sentiment",
          "refId": "A"
        }
      ],
      "title": "Score de sentiment NLP",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
